{
  "version": 2,
  "builds": [
    {
      "src": ".output/server/index.mjs",
      "use": "@vercel/node"
    },
    {
      "src": ".output/static/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/_nitro/(.*)",
      "dest": ".output/static/_nitro/$1",
      "headers": { "cache-control": "public, max-age=31536000, immutable" }
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": ".output/server/index.mjs"
    }
  ]
}