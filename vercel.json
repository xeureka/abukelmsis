{
  "version": 2,
  "framework": null,
  "outputDirectory": ".output/static",
  "cleanUrls": true,
  "routes": [
    {
      "src": "/_nitro/(.*)",
      "dest": "/_nitro/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": ".output/server/index.mjs"
    }
  ]
}